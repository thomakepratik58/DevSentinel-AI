# ---------- Application ----------
ENVIRONMENT=development
PROJECT_NAME=DevSentinel AI
API_V1_STR=/api/v1
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ---------- Database ----------
DATABASE_URL=postgresql+psycopg://devsentinel:devsentinel_local@localhost:5432/devsentinel

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0

# ---------- Security ----------
SECRET_KEY=replace-this-with-a-64-char-random-hex-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- OpenAI ----------
OPENAI_API_KEY=sk-replace-with-your-key
REASONING_MODEL=gpt-5.4
FAST_MODEL=gpt-5-mini
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
