# ============================================================
# DevSentinel AI — Environment Configuration
# ============================================================
#
# Runtime targets from project spec:
#   Node.js 24.15.0 LTS  |  Python 3.14.4  |  pnpm 11.0.6
#
# Locally verified during Milestone 1:
#   Node.js 22.19.0      |  Python 3.10.0  |  npm 10.x
#
# Next.js target: 15.5.3
# Installed and verified: 15.3.2
# ============================================================

# ---------- Application ----------
ENVIRONMENT=development
PROJECT_NAME=DevSentinel AI
API_V1_STR=/api/v1
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ---------- Database ----------
DATABASE_URL=postgresql+psycopg://devsentinel:devsentinel_local@localhost:5432/devsentinel

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0

# ---------- Security ----------
SECRET_KEY=replace-this-with-a-64-char-random-hex-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- OpenAI ----------
# All model names are configurable.
# REASONING_MODEL — primary reasoning model
# FAST_MODEL      — lower-cost summaries/classification model
# EMBEDDING_MODEL — retrieval embedding model
OPENAI_API_KEY=replace-with-openai-api-key
REASONING_MODEL=gpt-5.2
FAST_MODEL=gpt-5-mini
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072